--  TAB
-- ═══════════════════════════════════════════════════════════════════════════════
local Tab = {}
Tab.__index = Tab

function Tab.new(contentParent)
    local self   = setmetatable({}, Tab)
    self._parent = contentParent
    self._sections = {}

    -- Two-column layout frame
    local colFrame = Instance.new("Frame")
    colFrame.Size             = UDim2.new(1, 0, 1, 0)
    colFrame.BackgroundTransparency = 1
    colFrame.Visible          = false
    colFrame.Parent           = contentParent

    local colLayout = Instance.new("UIListLayout")
    colLayout.FillDirection   = Enum.FillDirection.Horizontal
    colLayout.SortOrder       = Enum.SortOrder.LayoutOrder
    colLayout.Padding         = UDim.new(0, 4)
    colLayout.Parent          = colFrame

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft   = UDim.new(0, 6)
    padding.PaddingRight  = UDim.new(0, 6)
    padding.PaddingTop    = UDim.new(0, 6)
    padding.PaddingBottom = UDim.new(0, 6)
    padding.Parent        = colFrame

    self._frame     = colFrame
    self._colFrame  = colFrame
    self._colCount  = 0
    return self
end

function Tab:AddSection(title)
    -- Alternate columns: 0 = left, 1 = right, 2 = left ...
    local colIdx = self._colCount % 2
    self._colCount += 1

    local section = Section.new(self._colFrame, title, colIdx, 2)
    table.insert(self._sections, section)
    return section
end


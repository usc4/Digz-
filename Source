--  TAB
-- ═══════════════════════════════════════════════════════════════════════════
local Tab = {}
Tab.__index = Tab

function Tab.new(contentParent)
    local self = setmetatable({}, Tab)

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,0,1,0); frame.BackgroundTransparency = 1
    frame.Visible = false; frame.Parent = contentParent

    local function makeCol(xScale, xOffset)
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(0.5,-5,1,0)
        scroll.Position = UDim2.new(xScale, xOffset, 0, 0)
        scroll.BackgroundTransparency = 1; scroll.BorderSizePixel = 0
        scroll.ScrollBarThickness = 2; scroll.ScrollBarImageColor3 = T.BORDER
        scroll.CanvasSize = UDim2.new(0,0,0,0)
        scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        scroll.Parent = frame
        local ll = Instance.new("UIListLayout")
        ll.FillDirection = Enum.FillDirection.Vertical
        ll.SortOrder = Enum.SortOrder.LayoutOrder
        ll.Padding = UDim.new(0,5); ll.Parent = scroll
        local p = Instance.new("UIPadding")
        p.PaddingLeft = UDim.new(0,4); p.PaddingRight = UDim.new(0,4)
        p.PaddingTop = UDim.new(0,5); p.PaddingBottom = UDim.new(0,5)
        p.Parent = scroll
        return scroll
    end

    self._frame    = frame
    self._cols     = { makeCol(0,4), makeCol(0.5,1) }
    self._colIdx   = 0
    self._sections = {}
    return self
end

function Tab:createsection(title)
    local col = self._cols[(self._colIdx % 2) + 1]
    self._colIdx = self._colIdx + 1
    local sec = Section.new(col, title)
    table.insert(self._sections, sec)
    return sec
end


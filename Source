local Section = {}
Section.__index = Section

function Section.new(parent, title)
    local self = setmetatable({}, Section)

    local card = Instance.new("Frame")
    card.Size=UDim2.new(1,0,0,0); card.AutomaticSize=Enum.AutomaticSize.Y
    card.BackgroundColor3=T.SURFACE; card.BorderSizePixel=0; card.Parent=parent
    rnd(card,5); brd(card,T.BORDER,1)

    local hdr = Instance.new("Frame")
    hdr.Size=UDim2.new(1,0,0,26); hdr.BackgroundColor3=T.SURFACE2
    hdr.BorderSizePixel=0; hdr.Parent=card; rnd(hdr,5)

    local hl = lbl(hdr, title, 12, T.ACCENT, FONT_SEMI)
    hl.Size=UDim2.new(1,-10,1,0); hl.Position=UDim2.new(0,10,0,0)

    local content = Instance.new("Frame")
    content.Size=UDim2.new(1,0,0,0); content.Position=UDim2.new(0,0,0,26)
    content.AutomaticSize=Enum.AutomaticSize.Y
    content.BackgroundTransparency=1; content.BorderSizePixel=0; content.Parent=card

    local ll = Instance.new("UIListLayout")
    ll.FillDirection=Enum.FillDirection.Vertical; ll.SortOrder=Enum.SortOrder.LayoutOrder
    ll.Padding=UDim.new(0,0); ll.Parent=content

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft=UDim.new(0,8); pad.PaddingRight=UDim.new(0,8)
    pad.PaddingTop=UDim.new(0,4); pad.PaddingBottom=UDim.new(0,6)
    pad.Parent=content

    self._content=content; self._rowOrder=0
    return self
end

function Section:_row(h)
    local r=Instance.new("Frame")
    r.Size=UDim2.new(1,0,0,h or ROW_H); r.BackgroundTransparency=1
    r.BorderSizePixel=0; r.LayoutOrder=self._rowOrder; r.Parent=self._content
    self._rowOrder=self._rowOrder+1
    return r
end

-- ── createtoggle ─────────────────────────────────────────────────────────────
function Section:createtoggle(text, default, callback)
    local row=self:_row(ROW_H); local state=(default==true)
    local nl=lbl(row,text,13,T.TEXT,FONT); nl.Size=UDim2.new(1,-48,1,0); nl.Position=UDim2.new(0,2,0,0)

    local pill=Instance.new("Frame")
    pill.Size=UDim2.new(0,36,0,19); pill.Position=UDim2.new(1,-37,0.5,-9.5)
    pill.BackgroundColor3=state and T.TOGGLE_ON or T.TOGGLE_OFF; pill.BorderSizePixel=0; pill.Parent=row; rnd(pill,10)

    local knob=Instance.new("Frame")
    knob.Size=UDim2.new(0,13,0,13)
    knob.Position=state and UDim2.new(1,-16,0.5,-6.5) or UDim2.new(0,3,0.5,-6.5)
    knob.BackgroundColor3=Color3.new(1,1,1); knob.BorderSizePixel=0; knob.ZIndex=3; knob.Parent=pill; rnd(knob,7)

    local btn=Instance.new("TextButton")
    btn.Size=UDim2.new(1,0,1,0); btn.BackgroundTransparency=1; btn.Text=""; btn.ZIndex=4; btn.Parent=row

    local function refresh()
        tw(pill,{BackgroundColor3=state and T.TOGGLE_ON or T.TOGGLE_OFF})
        tw(knob,{Position=state and UDim2.new(1,-16,0.5,-6.5) or UDim2.new(0,3,0.5,-6.5)})
    end
    onClick(btn,function() state=not state; refresh(); if callback then callback(state) end end)
    btn.MouseEnter:Connect(function() tw(nl,{TextColor3=T.TEXT_BRIGHT},0.08) end)
    btn.MouseLeave:Connect(function() tw(nl,{TextColor3=T.TEXT},0.08) end)

    return {
        getValue=function() return state end,
        setValue=function(v) state=v; refresh(); if callback then callback(state) end end,
    }
end

-- ── createslider ─────────────────────────────────────────────────────────────
function Section:createslider(text, min, max, default, callback)
    local lr=self:_row(20); local tr=self:_row(20)
    local value=math.clamp(default or min,min,max)
    local range=math.max(max-min,1)

    local nl=lbl(lr,text,12,T.TEXT_DIM,FONT); nl.Size=UDim2.new(0.62,0,1,0)
    local vl=lbl(lr,value.."/"..max,12,T.ACCENT,FONT,Enum.TextXAlignment.Right)
    vl.Size=UDim2.new(0.38,0,1,0); vl.Position=UDim2.new(0.62,0,0,0)

    local track=Instance.new("Frame")
    track.Size=UDim2.new(1,0,0,6); track.Position=UDim2.new(0,0,0.5,-3)
    track.BackgroundColor3=T.SLIDER_BG; track.BorderSizePixel=0; track.Parent=tr; rnd(track,3)

    local pct0=math.clamp((value-min)/range,0,1)
    local fill=Instance.new("Frame")
    fill.Size=UDim2.new(pct0,0,1,0); fill.BackgroundColor3=T.SLIDER_FILL
    fill.BorderSizePixel=0; fill.Parent=track; rnd(fill,3)

    local knob=Instance.new("Frame")
    knob.Size=UDim2.new(0,10,0,10); knob.Position=UDim2.new(pct0,-5,0.5,-5)
    knob.BackgroundColor3=Color3.new(1,1,1); knob.BorderSizePixel=0; knob.ZIndex=5; knob.Parent=track; rnd(knob,5)
    brd(knob,T.ACCENT,1.5)

    local hb=Instance.new("TextButton")
    hb.Size=UDim2.new(1,0,0,18); hb.Position=UDim2.new(0,0,0.5,-9)
    hb.BackgroundTransparency=1; hb.Text=""; hb.ZIndex=6; hb.Parent=track

    local sliding=false
    local function applyX(ax)
        local p=math.clamp((ax-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1)
        value=math.round(min+range*p)
        fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-5,0.5,-5); vl.Text=value.."/"..max
        if callback then callback(value) end
    end

    hb.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            sliding=true; applyX(i.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then applyX(i.Position.X) end
    end)

    return {
        getValue=function() return value end,
        setValue=function(v)
            value=math.clamp(v,min,max); local p=(value-min)/range
            fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-5,0.5,-5); vl.Text=value.."/"..max
        end,
    }
end

-- ── createbutton ─────────────────────────────────────────────────────────────
function Section:createbutton(text, callback)
    local row=self:_row(ROW_H-2)
    local btn=Instance.new("TextButton")
    btn.Size=UDim2.new(1,0,1,-6); btn.Position=UDim2.new(0,0,0,3)
    btn.BackgroundColor3=T.SURFACE2; btn.BorderSizePixel=0
    btn.Text=text; btn.TextColor3=T.TEXT; btn.Font=FONT_SEMI; btn.TextSize=12
    btn.Parent=row; rnd(btn,4); brd(btn,T.BORDER,1)
    btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=T.ACCENT,TextColor3=Color3.new(1,1,1)}) end)
    btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=T.SURFACE2,TextColor3=T.TEXT}) end)
    btn.MouseButton1Down:Connect(function() tw(btn,{BackgroundColor3=T.ACCENT_DIM},0.05) end)
    onClick(btn,function() tw(btn,{BackgroundColor3=T.ACCENT},0.05); if callback then callback() end end)
end

-- ── createdropdown ───────────────────────────────────────────────────────────
function Section:createdropdown(text, options, default, callback)
    local row=self:_row(ROW_H); local selected=default or options[1]; local listFrame; local open=false
    local nl=lbl(row,text,13,T.TEXT,FONT); nl.Size=UDim2.new(0.42,0,1,0)

    local db=Instance.new("TextButton")
    db.Size=UDim2.new(0.56,0,0.75,0); db.Position=UDim2.new(0.44,0,0.125,0)
    db.BackgroundColor3=T.SURFACE2; db.BorderSizePixel=0
    db.Text=selected.." ▾"; db.TextColor3=T.ACCENT; db.Font=FONT; db.TextSize=11
    db.TextTruncate=Enum.TextTruncate.AtEnd; db.Parent=row; rnd(db,4); brd(db,T.BORDER,1)

    local function closeList() open=false; if listFrame then listFrame:Destroy(); listFrame=nil end end
    local function openList()
        open=true; listFrame=Instance.new("Frame")
        listFrame.Size=UDim2.new(0,db.AbsoluteSize.X,0,#options*24+4)
        listFrame.BackgroundColor3=T.SURFACE3; listFrame.BorderSizePixel=0; listFrame.ZIndex=20
        local ry=row.AbsolutePosition.Y; local cy=self._content.AbsolutePosition.Y
        local dx=db.AbsolutePosition.X;  local cx=self._content.AbsolutePosition.X
        listFrame.Position=UDim2.new(0,dx-cx,0,ry-cy+ROW_H)
        listFrame.Parent=self._content; rnd(listFrame,4); brd(listFrame,T.ACCENT,1)
        local ll=Instance.new("UIListLayout"); ll.FillDirection=Enum.FillDirection.Vertical; ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Parent=listFrame
        for i,opt in ipairs(options) do
            local ob=Instance.new("TextButton")
            ob.Size=UDim2.new(1,0,0,24); ob.BackgroundColor3=T.SURFACE3; ob.BorderSizePixel=0
            ob.Text=opt; ob.TextColor3=opt==selected and T.ACCENT or T.TEXT
            ob.Font=FONT; ob.TextSize=11; ob.ZIndex=21; ob.LayoutOrder=i; ob.Parent=listFrame
            ob.MouseEnter:Connect(function() tw(ob,{BackgroundColor3=T.SURFACE2},0.07) end)
            ob.MouseLeave:Connect(function() tw(ob,{BackgroundColor3=T.SURFACE3},0.07) end)
            onClick(ob,function() selected=opt; db.Text=opt.." ▾"; closeList(); if callback then callback(opt) end end)
        end
    end
    onClick(db,function() if open then closeList() else openList() end end)
    return {
        getValue=function() return selected end,
        setValue=function(v) selected=v; db.Text=v.." ▾"; if callback then callback(v) end end,
    }
end

-- ── createkeybind ────────────────────────────────────────────────────────────
function Section:createkeybind(text, default, callback)
    local row=self:_row(ROW_H); local binding=default; local listening=false
    local nl=lbl(row,text,13,T.TEXT,FONT); nl.Size=UDim2.new(0.5,0,1,0)

    local keyBtn=Instance.new("TextButton")
    keyBtn.Size=UDim2.new(0.48,0,0.72,0); keyBtn.Position=UDim2.new(0.52,0,0.14,0)
    keyBtn.BackgroundColor3=T.SURFACE2; keyBtn.BorderSizePixel=0
    keyBtn.Text=binding and tostring(binding):gsub("Enum.KeyCode.","") or "None"
    keyBtn.TextColor3=T.ACCENT; keyBtn.Font=FONT; keyBtn.TextSize=11
    keyBtn.Parent=row; rnd(keyBtn,4); brd(keyBtn,T.BORDER,1)

    onClick(keyBtn,function()
        if listening then return end
        listening=true; keyBtn.Text="[ press key ]"; keyBtn.TextColor3=T.RED
    end)
    UIS.InputBegan:Connect(function(i,gp)
        if listening and not gp and i.UserInputType==Enum.UserInputType.Keyboard then
            binding=i.KeyCode; listening=false
            keyBtn.Text=tostring(i.KeyCode):gsub("Enum.KeyCode.",""); keyBtn.TextColor3=T.ACCENT
            if callback then callback(binding) end
        end
    end)
    return {getValue=function() return binding end}
end


--  TAB  (holds sections in two equal columns)
-- ═══════════════════════════════════════════════════════════════════════════
local Tab = {}
Tab.__index = Tab

function Tab.new(contentParent)
    local self = setmetatable({}, Tab)

    local frame = Instance.new("Frame")
    frame.Size                   = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Visible                = false
    frame.Parent                 = contentParent

    -- Two columns side by side
    local leftCol = Instance.new("Frame")
    leftCol.Size             = UDim2.new(0.5, -4, 1, 0)
    leftCol.Position         = UDim2.new(0, 0, 0, 0)
    leftCol.BackgroundTransparency = 1
    leftCol.Parent           = frame

    local leftList = Instance.new("UIListLayout")
    leftList.FillDirection = Enum.FillDirection.Vertical
    leftList.SortOrder     = Enum.SortOrder.LayoutOrder
    leftList.Padding       = UDim.new(0, 5)
    leftList.Parent        = leftCol

    local rightCol = Instance.new("Frame")
    rightCol.Size             = UDim2.new(0.5, -4, 1, 0)
    rightCol.Position         = UDim2.new(0.5, 4, 0, 0)
    rightCol.BackgroundTransparency = 1
    rightCol.Parent           = frame

    local rightList = Instance.new("UIListLayout")
    rightList.FillDirection = Enum.FillDirection.Vertical
    rightList.SortOrder     = Enum.SortOrder.LayoutOrder
    rightList.Padding       = UDim.new(0, 5)
    rightList.Parent        = rightCol

    -- Outer padding
    local pad = Instance.new("UIPadding")
    pad.PaddingLeft   = UDim.new(0, 6)
    pad.PaddingRight  = UDim.new(0, 6)
    pad.PaddingTop    = UDim.new(0, 6)
    pad.PaddingBottom = UDim.new(0, 6)
    pad.Parent        = frame

    self._frame    = frame
    self._cols     = { leftCol, rightCol }
    self._colIdx   = 0   -- 0-based, alternates
    self._sections = {}
    return self
end

function Tab:createsection(title)
    -- Pick left or right column
    local colIdx = (self._colIdx % 2) + 1
    self._colIdx = self._colIdx + 1
    local col    = self._cols[colIdx]

    -- Wrapper that auto-sizes
    local wrapper = Instance.new("Frame")
    wrapper.Size             = UDim2.new(1, 0, 0, 200) -- initial height, expands
    wrapper.BackgroundTransparency = 1
    wrapper.AutomaticSize    = Enum.AutomaticSize.Y
    wrapper.LayoutOrder      = #self._sections + 1
    wrapper.Parent           = col

    local sec = Section.new(wrapper, title)

    -- Make the section frame fill the wrapper
    local secFrame = wrapper:FindFirstChildOfClass("Frame")
    if secFrame then
        secFrame.Size = UDim2.new(1, 0, 0, 0)
        secFrame.AutomaticSize = Enum.AutomaticSize.Y
    end

    table.insert(self._sections, sec)
    return sec
end


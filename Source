    -- Close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size             = UDim2.new(0, 18, 0, 18)
    closeBtn.Position         = UDim2.new(1, -24, 0.5, -9)
    closeBtn.BackgroundColor3 = T.RED
    closeBtn.BorderSizePixel  = 0
    closeBtn.Text             = "✕"
    closeBtn.TextColor3       = Color3.new(1, 1, 1)
    closeBtn.Font             = FONT_BOLD
    closeBtn.TextSize         = 10
    closeBtn.Parent           = titleBar
    round(closeBtn, 9)

    closeBtn.MouseButton1Click:Connect(function()
        tw(win, { Size = UDim2.new(0, 550, 0, 0) }, 0.18)
        tw(shadow, { Size = UDim2.new(0, 556, 0, 0) }, 0.18)
        task.delay(0.2, function()
            win.Visible    = false
            shadow.Visible = false
        end)
    end)

    draggable(titleBar, win)
    -- Also move shadow with window
    UIS.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then
            shadow.Position = UDim2.new(
                win.Position.X.Scale, win.Position.X.Offset - 3,
                win.Position.Y.Scale, win.Position.Y.Offset - 3
            )
        end
    end)

    -- Tab bar
    local tabBar = Instance.new("Frame")
    tabBar.Size             = UDim2.new(1, 0, 0, 28)
    tabBar.Position         = UDim2.new(0, 0, 0, 30)
    tabBar.BackgroundColor3 = T.SURFACE
    tabBar.BorderSizePixel  = 0
    tabBar.Parent           = win

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.SortOrder     = Enum.SortOrder.LayoutOrder
    tabLayout.Padding       = UDim.new(0, 1)
    tabLayout.Parent        = tabBar

    local tabPad = Instance.new("UIPadding")
    tabPad.PaddingLeft = UDim.new(0, 4)
    tabPad.Parent      = tabBar

    -- Separator line under tab bar
    local sep = Instance.new("Frame")
    sep.Size             = UDim2.new(1, 0, 0, 1)
    sep.Position         = UDim2.new(0, 0, 0, 58)
    sep.BackgroundColor3 = T.BORDER
    sep.BorderSizePixel  = 0
    sep.Parent           = win

    -- Content area
    local content = Instance.new("Frame")
    content.Size                  = UDim2.new(1, 0, 1, -59)
    content.Position              = UDim2.new(0, 0, 0, 59)
    content.BackgroundTransparency = 1
    content.ClipsDescendants      = true
    content.Parent                = win

    self._win     = win
    self._tabBar  = tabBar
    self._content = content
    self._tabs    = {}
    self._visible = true

    -- Toggle visibility
    local key = toggleKey or Enum.KeyCode.RightShift
    UIS.InputBegan:Connect(function(i, gp)
        if not gp and i.KeyCode == key then
            self._visible = not self._visible
            win.Visible    = self._visible
            shadow.Visible = self._visible
        end
    end)

    return self
end

function Window:createtab(name)
    local idx = #self._tabs + 1
    local tab = Tab.new(self._content)

    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0, 85, 1, 0)
    btn.BackgroundColor3 = T.SURFACE
    btn.BorderSizePixel  = 0
    btn.Text             = name
    btn.TextColor3       = T.TEXT_DIM
    btn.Font             = FONT
    btn.TextSize         = 12
    btn.LayoutOrder      = idx
    btn.Parent           = self._tabBar

    -- Bottom active indicator
    local indicator = Instance.new("Frame")
    indicator.Size             = UDim2.new(0.6, 0, 0, 2)
    indicator.Position         = UDim2.new(0.2, 0, 1, -2)
    indicator.BackgroundColor3 = T.ACCENT
    indicator.BorderSizePixel  = 0
    indicator.Visible          = false
    indicator.Parent           = btn
    round(indicator, 1)

    btn.MouseButton1Click:Connect(function()
        self:_switch(idx)
    end)

    self._tabs[idx] = { tab = tab, btn = btn, ind = indicator }

    if idx == 1 then self:_switch(1) end

    return tab
end

function Window:_switch(idx)
    for i, data in ipairs(self._tabs) do
        local active = (i == idx)
        data.tab._frame.Visible = active
        data.ind.Visible        = active
        tw(data.btn, {
            TextColor3       = active and T.TAB_ACTIVE or T.TEXT_DIM,
            BackgroundColor3 = active and T.SURFACE2  or T.SURFACE,
        }, 0.1)
    end
end


    content.BackgroundTransparency = 1; content.ClipsDescendants = true; content.Parent = win

    self._win     = win
    self._tabBar  = tabBar
    self._content = content
    self._tabs    = {}
    self._visible = true
    self._winSize = UDim2.new(0,WIN_W,0,WIN_H)
    -- KEY is stored in a table so the InputBegan closure always reads the current value
    self._keyHolder = { key = toggleKey or Enum.KeyCode.RightShift }

    local function closeWindow()
        if not self._visible then return end
        self._visible = false
        tw(win, {Size=UDim2.new(0,WIN_W,0,0)}, 0.18)
        task.delay(0.2, function()
            win.Visible = false
            win.Size = self._winSize   -- restore so open works
        end)
        if mobileBtn then tw(mobileBtn, {BackgroundColor3=T.ACCENT_DIM},0.1) end
    end

    local function openWindow()
        if self._visible then return end
        self._visible = true
        win.Size = UDim2.new(0,WIN_W,0,0)
        win.Visible = true
        tw(win, {Size=self._winSize}, 0.18)
        if mobileBtn then tw(mobileBtn, {BackgroundColor3=T.ACCENT},0.1) end
    end

    onClick(closeBtn, closeWindow)

    if mobileBtn then
        onClick(mobileBtn, function()
            if self._visible then closeWindow() else openWindow() end
        end)
    end

    -- Toggle key — reads from _keyHolder.key so setkey works immediately
    UIS.InputBegan:Connect(function(i, gp)
        if not gp and i.UserInputType == Enum.UserInputType.Keyboard then
            if i.KeyCode == self._keyHolder.key then
                if self._visible then closeWindow() else openWindow() end
            end
        end
    end)

    self._closeWindow = closeWindow
    self._openWindow  = openWindow

    return self
end

-- setkey now updates the holder — the InputBegan closure will pick it up instantly
function Window:setkey(newKey)
    self._keyHolder.key = newKey
end

function Window:open()  self._openWindow()  end
function Window:close() self._closeWindow() end

function Window:createtab(name)
    local idx = #self._tabs + 1
    local tab = Tab.new(self._content)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0,85,1,0); btn.BackgroundColor3 = T.SURFACE
    btn.BorderSizePixel = 0; btn.Text = name; btn.TextColor3 = T.TAB_INACTIVE
    btn.Font = FONT; btn.TextSize = 12; btn.LayoutOrder = idx; btn.Parent = self._tabBar

    local ind = Instance.new("Frame")
    ind.Size = UDim2.new(0.6,0,0,2); ind.Position = UDim2.new(0.2,0,1,-2)
    ind.BackgroundColor3 = T.ACCENT; ind.BorderSizePixel = 0
    ind.Visible = false; ind.Parent = btn; rnd(ind,1)

    onClick(btn, function() self:_switch(idx) end)

    self._tabs[idx] = { tab=tab, btn=btn, ind=ind }
    if idx == 1 then self:_switch(1) end
    return tab
end

function Window:_switch(idx)
    for i,d in ipairs(self._tabs) do
        local active = (i == idx)
        d.tab._frame.Visible = active; d.ind.Visible = active
        tw(d.btn, {
            TextColor3       = active and T.TAB_ACTIVE   or T.TAB_INACTIVE,
            BackgroundColor3 = active and T.SURFACE2 or T.SURFACE,
        }, 0.1)
    end
end

-- ─── Public API ───────────────────────────────────────────────────────────────
local Digz = {}
Digz.__index = Digz

function Digz:createwindow(title, toggleKey)
    return Window.new(title, toggleKey)
end

return Digz

--  SECTION
-- ═══════════════════════════════════════════════════════════════════════════
local Section = {}
Section.__index = Section

function Section.new(parent, title)
    local self = setmetatable({}, Section)

    -- Outer wrapper — sized by parent's layout
    local frame = Instance.new("Frame")
    frame.BackgroundColor3  = T.SURFACE
    frame.BorderSizePixel   = 0
    frame.Size              = UDim2.new(1, 0, 1, 0)  -- fill column
    frame.LayoutOrder       = 0
    frame.Parent            = parent
    round(frame, 5)
    border(frame, T.BORDER, 1)

    -- Header
    local header = Instance.new("Frame")
    header.Size             = UDim2.new(1, 0, 0, 26)
    header.BackgroundColor3 = T.SURFACE2
    header.BorderSizePixel  = 0
    header.Parent           = frame
    round(header, 5)

    local headerLbl = Instance.new("TextLabel")
    headerLbl.Size              = UDim2.new(1, -10, 1, 0)
    headerLbl.Position          = UDim2.new(0, 10, 0, 0)
    headerLbl.BackgroundTransparency = 1
    headerLbl.Text              = title
    headerLbl.TextColor3        = T.ACCENT
    headerLbl.Font              = FONT_SEMI
    headerLbl.TextSize          = 12
    headerLbl.TextXAlignment    = Enum.TextXAlignment.Left
    headerLbl.Parent            = header

    -- Scrollable list
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size                  = UDim2.new(1, 0, 1, -26)
    scroll.Position              = UDim2.new(0, 0, 0, 26)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel       = 0
    scroll.ScrollBarThickness    = 2
    scroll.ScrollBarImageColor3  = T.BORDER
    scroll.CanvasSize            = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize   = Enum.AutomaticSize.Y
    scroll.ClipsDescendants      = true
    scroll.Parent                = frame

    local list = Instance.new("UIListLayout")
    list.FillDirection  = Enum.FillDirection.Vertical
    list.SortOrder      = Enum.SortOrder.LayoutOrder
    list.Padding        = UDim.new(0, 1)
    list.Parent         = scroll

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft   = UDim.new(0, 7)
    pad.PaddingRight  = UDim.new(0, 7)
    pad.PaddingTop    = UDim.new(0, 5)
    pad.PaddingBottom = UDim.new(0, 5)
    pad.Parent        = scroll

    self._scroll   = scroll
    self._rowOrder = 0
    return self
end

-- ── Internal row ─────────────────────────────────────────────────────────────
function Section:_row(h)
    local r = Instance.new("Frame")
    r.Size                  = UDim2.new(1, 0, 0, h or ROW_H)
    r.BackgroundTransparency = 1
    r.BorderSizePixel       = 0
    r.LayoutOrder           = self._rowOrder
    r.Parent                = self._scroll
    self._rowOrder          = self._rowOrder + 1
    return r
end

-- ── createtoggle ─────────────────────────────────────────────────────────────
function Section:createtoggle(text, default, callback)
    local row   = self:_row(ROW_H)
    local state = (default == true)

    -- Pill toggle on the right
    local pill = Instance.new("Frame")
    pill.Size             = UDim2.new(0, 34, 0, 18)
    pill.Position         = UDim2.new(1, -34, 0.5, -9)
    pill.BackgroundColor3 = state and T.TOGGLE_ON or T.TOGGLE_OFF
    pill.BorderSizePixel  = 0
    pill.Parent           = row
    round(pill, 9)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 12, 0, 12)
    knob.Position         = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 2
    knob.Parent           = pill
    round(knob, 6)

    -- Label
    local lbl = newLabel(row, text, 13, T.TEXT, FONT)
    lbl.Size     = UDim2.new(1, -44, 1, 0)
    lbl.Position = UDim2.new(0, 2, 0, 0)

    -- Clickable overlay
    local btn = Instance.new("TextButton")
    btn.Size                  = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text                  = ""
    btn.Parent                = row

    local function refresh()
        tw(pill, { BackgroundColor3 = state and T.TOGGLE_ON or T.TOGGLE_OFF })
        tw(knob, { Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6) })
    end

    btn.MouseButton1Click:Connect(function()
        state = not state
        refresh()
        if callback then callback(state) end
    end)
    btn.MouseEnter:Connect(function() tw(lbl, { TextColor3 = T.TEXT_BRIGHT }, 0.08) end)
    btn.MouseLeave:Connect(function() tw(lbl, { TextColor3 = T.TEXT }, 0.08) end)

    return {
        getValue  = function() return state end,
        setValue  = function(v)
            state = v
            refresh()
            if callback then callback(state) end
        end,
    }
end

-- ── createslider ─────────────────────────────────────────────────────────────
function Section:createslider(text, min, max, default, callback)
    -- Row 1: label + value
    local labelRow = self:_row(22)
    -- Row 2: track
    local trackRow = self:_row(20)

    local value = math.clamp(default or min, min, max)
    local pct   = (value - min) / math.max(max - min, 1)

    -- Label
    local nameLbl = newLabel(labelRow, text, 12, T.TEXT_DIM, FONT)
    nameLbl.Size = UDim2.new(0.6, 0, 1, 0)

    local valLbl = newLabel(labelRow, tostring(value) .. "/" .. tostring(max), 12, T.ACCENT, FONT, Enum.TextXAlignment.Right)
    valLbl.Size     = UDim2.new(0.4, 0, 1, 0)
    valLbl.Position = UDim2.new(0.6, 0, 0, 0)

    -- Track bg
    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1, 0, 0, 8)
    track.Position         = UDim2.new(0, 0, 0.5, -4)
    track.BackgroundColor3 = T.SLIDER_BG
    track.BorderSizePixel  = 0
    track.ClipsDescendants = false
    track.Parent           = trackRow
    round(track, 4)
    border(track, T.BORDER, 1)

    -- Fill
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new(math.max(pct, 0.001), 0, 1, 0)
    fill.BackgroundColor3 = T.SLIDER_FILL
    fill.BorderSizePixel  = 0
    fill.Parent           = track
    round(fill, 4)

    -- Knob
    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 14, 0, 14)
    knob.Position         = UDim2.new(pct, -7, 0.5, -7)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 5
    knob.Parent           = track
    round(knob, 7)
    border(knob, T.ACCENT, 2)

    -- Input
    local hitbox = Instance.new("TextButton")
    hitbox.Size                   = UDim2.new(1, 0, 0, 20)
    hitbox.Position               = UDim2.new(0, 0, 0.5, -10)
    hitbox.BackgroundTransparency = 1
    hitbox.Text                   = ""
    hitbox.ZIndex                 = 6
    hitbox.Parent                 = track

    local dragging = false

    local function updateFromX(absX)
        local tAbs = track.AbsolutePosition.X
        local tW   = track.AbsoluteSize.X
        local p    = math.clamp((absX - tAbs) / math.max(tW, 1), 0, 1)
        local v    = math.round(min + (max - min) * p)
        value      = v
        local fp   = (v - min) / math.max(max - min, 1)
        fill.Size      = UDim2.new(math.max(fp, 0.001), 0, 1, 0)
        knob.Position  = UDim2.new(fp, -7, 0.5, -7)
        valLbl.Text    = tostring(v) .. "/" .. tostring(max)
        if callback then callback(v) end
    end

    hitbox.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromX(i.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(i.Position.X)
        end
    end)

    return {
        getValue = function() return value end,
        setValue = function(v)
            value = math.clamp(v, min, max)
            updateFromX(track.AbsolutePosition.X + (value - min) / math.max(max - min, 1) * track.AbsoluteSize.X)
        end,
    }
end


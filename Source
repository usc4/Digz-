-- ── createdropdown ───────────────────────────────────────────────────────────
function Section:createdropdown(text, options, default, callback)
    local row      = self:_row(ROW_H)
    local selected = default or options[1]
    local open     = false
    local listFrame

    local nameLbl = newLabel(row, text, 13, T.TEXT, FONT)
    nameLbl.Size = UDim2.new(0.42, 0, 1, 0)

    local dropBtn = Instance.new("TextButton")
    dropBtn.Size             = UDim2.new(0.56, 0, 0.78, 0)
    dropBtn.Position         = UDim2.new(0.44, 0, 0.11, 0)
    dropBtn.BackgroundColor3 = T.SURFACE2
    dropBtn.BorderSizePixel  = 0
    dropBtn.Text             = selected .. "  ▾"
    dropBtn.TextColor3       = T.ACCENT
    dropBtn.Font             = FONT
    dropBtn.TextSize         = 11
    dropBtn.TextTruncate     = Enum.TextTruncate.AtEnd
    dropBtn.Parent           = row
    round(dropBtn, 4)
    border(dropBtn, T.BORDER, 1)

    local function closeList()
        open = false
        if listFrame then
            listFrame:Destroy()
            listFrame = nil
        end
    end

    local function openList()
        open = true
        listFrame = Instance.new("Frame")
        listFrame.Size             = UDim2.new(0.56, 0, 0, #options * 24 + 4)
        listFrame.BackgroundColor3 = T.SURFACE3
        listFrame.BorderSizePixel  = 0
        listFrame.ZIndex           = 20
        -- position below the dropBtn inside the scroll
        local rowAbs  = row.AbsolutePosition
        local scrollAbs = self._scroll.AbsolutePosition
        local relY    = rowAbs.Y - scrollAbs.Y + self._scroll.CanvasPosition.Y + ROW_H
        listFrame.Position = UDim2.new(0.44, 0, 0, relY + 2)
        listFrame.Parent   = self._scroll
        round(listFrame, 4)
        border(listFrame, T.ACCENT, 1)

        local ll = Instance.new("UIListLayout")
        ll.FillDirection = Enum.FillDirection.Vertical
        ll.SortOrder     = Enum.SortOrder.LayoutOrder
        ll.Parent        = listFrame

        local lp = Instance.new("UIPadding")
        lp.PaddingTop    = UDim.new(0, 2)
        lp.PaddingBottom = UDim.new(0, 2)
        lp.Parent        = listFrame

        for i, opt in ipairs(options) do
            local ob = Instance.new("TextButton")
            ob.Size             = UDim2.new(1, 0, 0, 24)
            ob.BackgroundColor3 = T.SURFACE3
            ob.BorderSizePixel  = 0
            ob.Text             = opt
            ob.TextColor3       = opt == selected and T.ACCENT or T.TEXT
            ob.Font             = FONT
            ob.TextSize         = 12
            ob.ZIndex           = 21
            ob.LayoutOrder      = i
            ob.Parent           = listFrame
            ob.MouseEnter:Connect(function() tw(ob, { BackgroundColor3 = T.SURFACE2 }, 0.07) end)
            ob.MouseLeave:Connect(function() tw(ob, { BackgroundColor3 = T.SURFACE3 }, 0.07) end)
            ob.MouseButton1Click:Connect(function()
                selected      = opt
                dropBtn.Text  = opt .. "  ▾"
                closeList()
                if callback then callback(opt) end
            end)
        end
    end

    dropBtn.MouseButton1Click:Connect(function()
        if open then closeList() else openList() end
    end)

    return {
        getValue = function() return selected end,
        setValue = function(v)
            selected     = v
            dropBtn.Text = v .. "  ▾"
            if callback then callback(v) end
        end,
    }
end

-- ── createkeybind ────────────────────────────────────────────────────────────
function Section:createkeybind(text, default, callback)
    local row       = self:_row(ROW_H)
    local binding   = default
    local listening = false

    local nameLbl = newLabel(row, text, 13, T.TEXT, FONT)
    nameLbl.Size = UDim2.new(0.5, 0, 1, 0)

    local keyBtn = Instance.new("TextButton")
    keyBtn.Size             = UDim2.new(0.48, 0, 0.72, 0)
    keyBtn.Position         = UDim2.new(0.52, 0, 0.14, 0)
    keyBtn.BackgroundColor3 = T.SURFACE2
    keyBtn.BorderSizePixel  = 0
    keyBtn.Text             = binding and tostring(binding):gsub("Enum.KeyCode.", "") or "None"
    keyBtn.TextColor3       = T.ACCENT
    keyBtn.Font             = FONT
    keyBtn.TextSize         = 11
    keyBtn.Parent           = row
    round(keyBtn, 4)
    border(keyBtn, T.BORDER, 1)

    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening      = true
        keyBtn.Text    = "[ press key ]"
        keyBtn.TextColor3 = T.RED
    end)

    UIS.InputBegan:Connect(function(i, gp)
        if listening and not gp and i.UserInputType == Enum.UserInputType.Keyboard then
            binding            = i.KeyCode
            listening          = false
            keyBtn.Text        = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
            keyBtn.TextColor3  = T.ACCENT
            if callback then callback(binding) end
        end
    end)

    return { getValue = function() return binding end }
end


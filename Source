}

local FONT      = Enum.Font.Code
local FONT_SEMI = Enum.Font.GothamSemibold
local FONT_BOLD = Enum.Font.GothamBold
local ROW_H     = 30

local function rnd(inst, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 5); c.Parent = inst
end
local function brd(inst, col, thick)
    local s = Instance.new("UIStroke"); s.Color = col or T.BORDER; s.Thickness = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = inst
end
local function tw(obj, props, t)
    TweenService:Create(obj, TweenInfo.new(t or 0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end
local function lbl(parent, text, size, color, font, xAlign)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1
    l.Text = text or ""; l.TextColor3 = color or T.TEXT
    l.Font = font or FONT; l.TextSize = size or 13
    l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd; l.Parent = parent
    return l
end
local function makeDraggable(handle, target)
    local down, origin, ws = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            down = true; origin = i.Position; ws = target.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then down = false end
    end)
    UIS.InputChanged:Connect(function(i)
        if down and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - origin
            target.Position = UDim2.new(ws.X.Scale, ws.X.Offset+d.X, ws.Y.Scale, ws.Y.Offset+d.Y)
        end
    end)
end

-- SECTION
local Section = {}
Section.__index = Section

function Section.new(columnParent, title)
    local self = setmetatable({}, Section)

    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 0)
    card.AutomaticSize = Enum.AutomaticSize.Y
    card.BackgroundColor3 = T.SURFACE
    card.BorderSizePixel = 0
    card.Parent = columnParent
    rnd(card, 5); brd(card, T.BORDER, 1)

    local header = Instance.new("Frame")
    header.Size = UDim2.new(1, 0, 0, 26)
    header.BackgroundColor3 = T.SURFACE2
    header.BorderSizePixel = 0
    header.Parent = card
    rnd(header, 5)

    local hl = Instance.new("TextLabel")
    hl.Size = UDim2.new(1,-10,1,0); hl.Position = UDim2.new(0,10,0,0)
    hl.BackgroundTransparency = 1; hl.Text = title
    hl.TextColor3 = T.ACCENT; hl.Font = FONT_SEMI; hl.TextSize = 12
    hl.TextXAlignment = Enum.TextXAlignment.Left; hl.Parent = header

    local content = Instance.new("Frame")
    content.Size = UDim2.new(1,0,0,0)
    content.Position = UDim2.new(0,0,0,26)
    content.AutomaticSize = Enum.AutomaticSize.Y
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.Parent = card

    local ll = Instance.new("UIListLayout")
    ll.FillDirection = Enum.FillDirection.Vertical
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding = UDim.new(0, 0)
    ll.Parent = content

    local pad = Instance.new("UIPadding")
    pad.PaddingLeft = UDim.new(0,8); pad.PaddingRight = UDim.new(0,8)
    pad.PaddingTop = UDim.new(0,4); pad.PaddingBottom = UDim.new(0,6)
    pad.Parent = content

    self._content = content
    self._rowOrder = 0
    return self
end

function Section:_row(h)
    local r = Instance.new("Frame")
    r.Size = UDim2.new(1,0,0,h or ROW_H)
    r.BackgroundTransparency = 1; r.BorderSizePixel = 0
    r.LayoutOrder = self._rowOrder; r.Parent = self._content
    self._rowOrder = self._rowOrder + 1
    return r
end

function Section:createtoggle(text, default, callback)
    local row = self:_row(ROW_H); local state = (default == true)
    local nameLbl = lbl(row, text, 13, T.TEXT, FONT)
    nameLbl.Size = UDim2.new(1,-48,1,0); nameLbl.Position = UDim2.new(0,2,0,0)

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0,36,0,19); pill.Position = UDim2.new(1,-37,0.5,-9.5)
    pill.BackgroundColor3 = state and T.TOGGLE_ON or T.TOGGLE_OFF
    pill.BorderSizePixel = 0; pill.Parent = row; rnd(pill, 10)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,13,0,13)
    knob.Position = state and UDim2.new(1,-16,0.5,-6.5) or UDim2.new(0,3,0.5,-6.5)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0
    knob.ZIndex = 3; knob.Parent = pill; rnd(knob, 7)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.ZIndex = 4; btn.Parent = row

    local function refresh()
        tw(pill, {BackgroundColor3 = state and T.TOGGLE_ON or T.TOGGLE_OFF})
        tw(knob, {Position = state and UDim2.new(1,-16,0.5,-6.5) or UDim2.new(0,3,0.5,-6.5)})
    end
    btn.MouseButton1Click:Connect(function() state = not state; refresh(); if callback then callback(state) end end)
    btn.MouseEnter:Connect(function() tw(nameLbl, {TextColor3=T.TEXT_BRIGHT}, 0.08) end)
    btn.MouseLeave:Connect(function() tw(nameLbl, {TextColor3=T.TEXT}, 0.08) end)

    return {
        getValue = function() return state end,
        setValue = function(v) state=v; refresh(); if callback then callback(state) end end,
    }
end

function Section:createslider(text, min, max, default, callback)
    local labelRow = self:_row(20); local trackRow = self:_row(22)
    local value = math.clamp(default or min, min, max)
    local range = math.max(max - min, 1)

    local nameLbl = lbl(labelRow, text, 12, T.TEXT_DIM, FONT)
    nameLbl.Size = UDim2.new(0.62,0,1,0)
    local valLbl = lbl(labelRow, value.."/"..max, 12, T.ACCENT, FONT, Enum.TextXAlignment.Right)
    valLbl.Size = UDim2.new(0.38,0,1,0); valLbl.Position = UDim2.new(0.62,0,0,0)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,0,0,8); track.Position = UDim2.new(0,0,0.5,-4)
    track.BackgroundColor3 = T.SLIDER_BG; track.BorderSizePixel = 0; track.Parent = trackRow
    rnd(track, 4)

    local pct0 = math.clamp((value-min)/range, 0, 1)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(pct0,0,1,0); fill.BackgroundColor3 = T.SLIDER_FILL
    fill.BorderSizePixel = 0; fill.Parent = track; rnd(fill, 4)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,14,0,14); knob.Position = UDim2.new(pct0,-7,0.5,-7)
    knob.BackgroundColor3 = Color3.new(1,1,1); knob.BorderSizePixel = 0
    knob.ZIndex = 5; knob.Parent = track; rnd(knob, 7); brd(knob, T.ACCENT, 2)

    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1,10,0,22); hitbox.Position = UDim2.new(0,-5,0.5,-11)
    hitbox.BackgroundTransparency = 1; hitbox.Text = ""; hitbox.ZIndex = 6; hitbox.Parent = track

    local sliding = false
    local function applyX(absX)
        local p = math.clamp((absX - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X,1), 0, 1)
        value = math.round(min + range * p)
        fill.Size = UDim2.new(p,0,1,0); knob.Position = UDim2.new(p,-7,0.5,-7)
        valLbl.Text = value.."/"..max
        if callback then callback(value) end
    end
    hitbox.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding=true; applyX(i.Position.X) end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then applyX(i.Position.X) end
    end)
    return {
        getValue = function() return value end,
        setValue = function(v)
            value = math.clamp(v,min,max); local p=(value-min)/range
            fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-7,0.5,-7); valLbl.Text=value.."/"..max
        end,
    }
end

function Section:createbutton(text, callback)
    local row = self:_row(ROW_H-2)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,-6); btn.Position = UDim2.new(0,0,0,3)
    btn.BackgroundColor3 = T.SURFACE2; btn.BorderSizePixel = 0
    btn.Text = text; btn.TextColor3 = T.TEXT; btn.Font = FONT_SEMI; btn.TextSize = 12
    btn.Parent = row; rnd(btn,4); brd(btn, T.BORDER, 1)
    btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=T.ACCENT,TextColor3=Color3.new(1,1,1)}) end)
    btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=T.SURFACE2,TextColor3=T.TEXT}) end)
    btn.MouseButton1Down:Connect(function() tw(btn,{BackgroundColor3=T.ACCENT_DIM},0.05) end)
    btn.MouseButton1Click:Connect(function() tw(btn,{BackgroundColor3=T.ACCENT},0.05); if callback then callback() end end)
end

function Section:createdropdown(text, options, default, callback)
    local row = self:_row(ROW_H); local selected = default or options[1]; local listFrame
    local nameLbl = lbl(row, text, 13, T.TEXT, FONT); nameLbl.Size = UDim2.new(0.42,0,1,0)
    local dropBtn = Instance.new("TextButton")
    dropBtn.Size = UDim2.new(0.56,0,0.75,0); dropBtn.Position = UDim2.new(0.44,0,0.125,0)
    dropBtn.BackgroundColor3 = T.SURFACE2; dropBtn.BorderSizePixel = 0
    dropBtn.Text = selected.." ▾"; dropBtn.TextColor3 = T.ACCENT
    dropBtn.Font = FONT; dropBtn.TextSize = 11; dropBtn.TextTruncate = Enum.TextTruncate.AtEnd
    dropBtn.Parent = row; rnd(dropBtn,4); brd(dropBtn, T.BORDER, 1)
    local open = false
    local function closeList() open=false; if listFrame then listFrame:Destroy(); listFrame=nil end end
    local function openList()
        open=true; listFrame=Instance.new("Frame")
        listFrame.Size = UDim2.new(0, dropBtn.AbsoluteSize.X, 0, #options*24+4)
        listFrame.BackgroundColor3 = T.SURFACE3; listFrame.BorderSizePixel = 0; listFrame.ZIndex = 20
        local rowAbsY=row.AbsolutePosition.Y; local cAbsY=self._content.AbsolutePosition.Y
        local dAbsX=dropBtn.AbsolutePosition.X; local cAbsX=self._content.AbsolutePosition.X
        listFrame.Position = UDim2.new(0, dAbsX-cAbsX, 0, rowAbsY-cAbsY+ROW_H)
        listFrame.Parent = self._content; rnd(listFrame,4); brd(listFrame, T.ACCENT, 1)
        local ll=Instance.new("UIListLayout"); ll.FillDirection=Enum.FillDirection.Vertical
        ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Parent=listFrame
        for i,opt in ipairs(options) do
            local ob=Instance.new("TextButton"); ob.Size=UDim2.new(1,0,0,24)
            ob.BackgroundColor3=T.SURFACE3; ob.BorderSizePixel=0; ob.Text=opt
            ob.TextColor3=opt==selected and T.ACCENT or T.TEXT; ob.Font=FONT; ob.TextSize=11
            ob.ZIndex=21; ob.LayoutOrder=i; ob.Parent=listFrame
            ob.MouseEnter:Connect(function() tw(ob,{BackgroundColor3=T.SURFACE2},0.07) end)
            ob.MouseLeave:Connect(function() tw(ob,{BackgroundColor3=T.SURFACE3},0.07) end)
            ob.MouseButton1Click:Connect(function()
                selected=opt; dropBtn.Text=opt.." ▾"; closeList(); if callback then callback(opt) end
            end)
        end
    end
    dropBtn.MouseButton1Click:Connect(function() if open then closeList() else openList() end end)
    return {
        getValue=function() return selected end,
        setValue=function(v) selected=v; dropBtn.Text=v.." ▾"; if callback then callback(v) end end,
    }
end

function Section:createkeybind(text, default, callback)
    local row=self:_row(ROW_H); local binding=default; local listening=false
    local nameLbl=lbl(row,text,13,T.TEXT,FONT); nameLbl.Size=UDim2.new(0.5,0,1,0)
    local keyBtn=Instance.new("TextButton")
    keyBtn.Size=UDim2.new(0.48,0,0.72,0); keyBtn.Position=UDim2.new(0.52,0,0.14,0)
    keyBtn.BackgroundColor3=T.SURFACE2; keyBtn.BorderSizePixel=0
    keyBtn.Text=binding and tostring(binding):gsub("Enum.KeyCode.","") or "None"
    keyBtn.TextColor3=T.ACCENT; keyBtn.Font=FONT; keyBtn.TextSize=11
    keyBtn.Parent=row; rnd(keyBtn,4); brd(keyBtn,T.BORDER,1)
    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening=true; keyBtn.Text="[ press key ]"; keyBtn.TextColor3=T.RED
    end)
    UIS.InputBegan:Connect(function(i,gp)
        if listening and not gp and i.UserInputType==Enum.UserInputType.Keyboard then
            binding=i.KeyCode; listening=false
            keyBtn.Text=tostring(i.KeyCode):gsub("Enum.KeyCode.",""); keyBtn.TextColor3=T.ACCENT
            if callback then callback(binding) end
        end
    end)
    return {getValue=function() return binding end}
end

function Section:createlabel(text)

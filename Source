    BG          = Color3.fromRGB(13,  13,  18),
    SURFACE     = Color3.fromRGB(20,  20,  28),
    SURFACE2    = Color3.fromRGB(28,  28,  40),
    SURFACE3    = Color3.fromRGB(36,  36,  52),
    BORDER      = Color3.fromRGB(48,  48,  65),
    ACCENT      = Color3.fromRGB(80,  155, 255),
    ACCENT_DIM  = Color3.fromRGB(45,  95,  175),
    GREEN       = Color3.fromRGB(0,   200, 110),
    RED         = Color3.fromRGB(220, 65,  65),
    TEXT        = Color3.fromRGB(215, 215, 225),
    TEXT_DIM    = Color3.fromRGB(115, 115, 135),
    TEXT_BRIGHT = Color3.fromRGB(245, 245, 255),
    TOGGLE_OFF  = Color3.fromRGB(48,  48,  66),
    TOGGLE_ON   = Color3.fromRGB(0,   195, 108),
    SLIDER_BG   = Color3.fromRGB(32,  32,  48),
    SLIDER_FILL = Color3.fromRGB(80,  155, 255),
    TAB_BG      = Color3.fromRGB(10,  10,  15),
    TAB_ACTIVE  = Color3.fromRGB(80,  155, 255),

    closeBtn.BorderSizePixel  = 0
    closeBtn.Text             = "✕"
    closeBtn.TextColor3       = Color3.new(1,1,1)
    closeBtn.Font             = FONT_BOLD
    closeBtn.TextSize         = 11
    closeBtn.Parent           = titleBar
    corner(closeBtn, 10)

    closeBtn.MouseButton1Click:Connect(function()
        tween(win, { Size = UDim2.new(0, 540, 0, 0) }, 0.2)
        task.delay(0.25, function() win.Visible = false end)
    end)

    makeDraggable(titleBar, win)

    -- Tab bar
    local tabBar = Instance.new("Frame")
    tabBar.Size             = UDim2.new(1, 0, 0, 26)
    tabBar.Position         = UDim2.new(0, 0, 0, 28)
    tabBar.BackgroundColor3 = THEME.SURFACE
    tabBar.BorderSizePixel  = 0
    tabBar.Parent           = win

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection  = Enum.FillDirection.Horizontal
    tabLayout.SortOrder      = Enum.SortOrder.LayoutOrder
    tabLayout.Padding        = UDim.new(0, 0)
    tabLayout.Parent         = tabBar

    -- Content area
    local contentArea = Instance.new("Frame")
    contentArea.Size             = UDim2.new(1, 0, 1, -54)
    contentArea.Position         = UDim2.new(0, 0, 0, 54)
    contentArea.BackgroundTransparency = 1
    contentArea.Parent           = win

    self._win         = win
    self._tabBar      = tabBar
    self._contentArea = contentArea
    self._tabs        = {}
    self._tabBtns     = {}
    self._activeTab   = nil

    -- Toggle key
    local visible = true
    local key     = toggleKey or Enum.KeyCode.RightShift
    UserInputService.InputBegan:Connect(function(i, gp)
        if not gp and i.KeyCode == key then
            visible = not visible
            win.Visible = visible
        end
    end)

    return self
end

function Window:AddTab(name)
    local idx  = #self._tabs + 1
    local tab  = Tab.new(self._contentArea)

    -- Tab button
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0, 90, 1, 0)
    btn.BackgroundColor3 = THEME.SURFACE
    btn.BorderSizePixel  = 0
    btn.Text             = name
    btn.TextColor3       = THEME.TAB_INACTIVE
    btn.Font             = FONT
    btn.TextSize         = 13
    btn.LayoutOrder      = idx
    btn.Parent           = self._tabBar

    -- Active indicator line
    local line = Instance.new("Frame")
    line.Size             = UDim2.new(0.7, 0, 0, 2)
    line.Position         = UDim2.new(0.15, 0, 1, -2)
    line.BackgroundColor3 = THEME.ACCENT
    line.BorderSizePixel  = 0
    line.Visible          = false
    line.Parent           = btn
    corner(line, 1)

    btn.MouseButton1Click:Connect(function()
        self:_switchTab(idx)
    end)

    self._tabs[idx]    = { tab = tab, btn = btn, line = line }
    self._tabBtns[idx] = btn

    if idx == 1 then
        self:_switchTab(1)
    end

    return tab
end

function Window:_switchTab(idx)
    for i, data in ipairs(self._tabs) do
        data.tab._frame.Visible = (i == idx)
        data.line.Visible       = (i == idx)
        tween(data.btn, {
            TextColor3       = (i == idx) and THEME.TAB_ACTIVE or THEME.TAB_INACTIVE,
            BackgroundColor3 = (i == idx) and THEME.SURFACE2  or THEME.SURFACE,
        }, 0.1)
    end
    self._activeTab = idx
end

-- ─── Public API ───────────────────────────────────────────────────────────────
function UILibrary.CreateWindow(title, toggleKey)
    return Window.new(title, toggleKey)
end

return UILibrary

end

-- TAB
local Tab = {}
Tab.__index = Tab

function Tab.new(contentParent)
    local self = setmetatable({}, Tab)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,0,1,0); frame.BackgroundTransparency=1
    frame.Visible=false; frame.Parent=contentParent

    local function makeCol(xScale, xOffset)
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(0.5,-5,1,0)
        scroll.Position = UDim2.new(xScale, xOffset, 0, 0)
        scroll.BackgroundTransparency=1; scroll.BorderSizePixel=0
        scroll.ScrollBarThickness=2; scroll.ScrollBarImageColor3=T.BORDER
        scroll.CanvasSize=UDim2.new(0,0,0,0); scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
        scroll.Parent=frame
        local ll=Instance.new("UIListLayout"); ll.FillDirection=Enum.FillDirection.Vertical
        ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,5); ll.Parent=scroll
        local p=Instance.new("UIPadding")
        p.PaddingLeft=UDim.new(0,4); p.PaddingRight=UDim.new(0,4)
        p.PaddingTop=UDim.new(0,5); p.PaddingBottom=UDim.new(0,5); p.Parent=scroll
        return scroll
    end

    self._frame  = frame
    self._cols   = { makeCol(0, 4), makeCol(0.5, 1) }
    self._colIdx = 0
    self._sections = {}
    return self
end

function Tab:createsection(title)
    local col = self._cols[(self._colIdx % 2) + 1]
    self._colIdx = self._colIdx + 1
    local sec = Section.new(col, title)
    table.insert(self._sections, sec)
    return sec
end

-- WINDOW
local Window = {}
Window.__index = Window

function Window.new(title, toggleKey)
    local self = setmetatable({}, Window)
    local sg = Instance.new("ScreenGui")
    sg.Name="DigzUI"; sg.ResetOnSpawn=false
    sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; sg.DisplayOrder=999; sg.Parent=playerGui

    local win = Instance.new("Frame")
    win.Name="Window"; win.Size=UDim2.new(0,550,0,415)
    win.Position=UDim2.new(0.5,-275,0.5,-207)
    win.BackgroundColor3=T.BG; win.BorderSizePixel=0; win.Parent=sg
    rnd(win,6); brd(win,T.BORDER,1)

    local titleBar=Instance.new("Frame")
    titleBar.Size=UDim2.new(1,0,0,30); titleBar.BackgroundColor3=T.TAB_BG
    titleBar.BorderSizePixel=0; titleBar.Parent=win; rnd(titleBar,6)

    local accent=Instance.new("Frame")
    accent.Size=UDim2.new(0,3,0.65,0); accent.Position=UDim2.new(0,7,0.175,0)
    accent.BackgroundColor3=T.ACCENT; accent.BorderSizePixel=0; accent.Parent=titleBar; rnd(accent,2)

    local titleLbl=lbl(titleBar,title,12,T.TEXT,FONT_SEMI)
    titleLbl.Size=UDim2.new(1,-55,1,0); titleLbl.Position=UDim2.new(0,16,0,0)

    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,18,0,18); closeBtn.Position=UDim2.new(1,-24,0.5,-9)
    closeBtn.BackgroundColor3=T.RED; closeBtn.BorderSizePixel=0
    closeBtn.Text="✕"; closeBtn.TextColor3=Color3.new(1,1,1)
    closeBtn.Font=FONT_BOLD; closeBtn.TextSize=10; closeBtn.Parent=titleBar; rnd(closeBtn,9)
    closeBtn.MouseButton1Click:Connect(function()
        tw(win,{Size=UDim2.new(0,550,0,0)},0.18)
        task.delay(0.2,function() win.Visible=false end)
    end)
    makeDraggable(titleBar, win)

    local tabBar=Instance.new("Frame")
    tabBar.Size=UDim2.new(1,0,0,28); tabBar.Position=UDim2.new(0,0,0,30)
    tabBar.BackgroundColor3=T.SURFACE; tabBar.BorderSizePixel=0; tabBar.Parent=win
    local tl=Instance.new("UIListLayout"); tl.FillDirection=Enum.FillDirection.Horizontal
    tl.SortOrder=Enum.SortOrder.LayoutOrder; tl.Padding=UDim.new(0,1); tl.Parent=tabBar
    local tp=Instance.new("UIPadding"); tp.PaddingLeft=UDim.new(0,4); tp.Parent=tabBar

    local sep=Instance.new("Frame")
    sep.Size=UDim2.new(1,0,0,1); sep.Position=UDim2.new(0,0,0,58)
    sep.BackgroundColor3=T.BORDER; sep.BorderSizePixel=0; sep.Parent=win

    local content=Instance.new("Frame")
    content.Size=UDim2.new(1,0,1,-60); content.Position=UDim2.new(0,0,0,60)
    content.BackgroundTransparency=1; content.ClipsDescendants=true; content.Parent=win

    self._win=win; self._tabBar=tabBar; self._content=content; self._tabs={}; self._visible=true

    local key=toggleKey or Enum.KeyCode.RightShift
    UIS.InputBegan:Connect(function(i,gp)
        if not gp and i.KeyCode==key then self._visible=not self._visible; win.Visible=self._visible end
    end)
    return self
end

function Window:createtab(name)
    local idx=#self._tabs+1
    local tab=Tab.new(self._content)
    local btn=Instance.new("TextButton")
    btn.Size=UDim2.new(0,85,1,0); btn.BackgroundColor3=T.SURFACE; btn.BorderSizePixel=0
    btn.Text=name; btn.TextColor3=T.TAB_INACTIVE; btn.Font=FONT; btn.TextSize=12
    btn.LayoutOrder=idx; btn.Parent=self._tabBar
    local ind=Instance.new("Frame")
    ind.Size=UDim2.new(0.6,0,0,2); ind.Position=UDim2.new(0.2,0,1,-2)
    ind.BackgroundColor3=T.ACCENT; ind.BorderSizePixel=0; ind.Visible=false; ind.Parent=btn; rnd(ind,1)
    btn.MouseButton1Click:Connect(function() self:_switch(idx) end)
    self._tabs[idx]={tab=tab,btn=btn,ind=ind}
    if idx==1 then self:_switch(1) end
    return tab
end

function Window:_switch(idx)
    for i,d in ipairs(self._tabs) do
        local active=(i==idx)
        d.tab._frame.Visible=active; d.ind.Visible=active
        tw(d.btn,{TextColor3=active and T.TAB_ACTIVE or T.TAB_INACTIVE, BackgroundColor3=active and T.SURFACE2 or T.SURFACE},0.1)
    end
end


--  TAB
-- ═══════════════════════════════════════════════════════════════════════════
local Tab = {}
Tab.__index = Tab

function Tab.new(parent)
    local self=setmetatable({},Tab)
    local frame=Instance.new("Frame")
    frame.Size=UDim2.new(1,0,1,0); frame.BackgroundTransparency=1
    frame.Visible=false; frame.Parent=parent

    local function makeCol(xs,xo)
        local s=Instance.new("ScrollingFrame")
        s.Size=UDim2.new(0.5,-5,1,0); s.Position=UDim2.new(xs,xo,0,0)
        s.BackgroundTransparency=1; s.BorderSizePixel=0
        s.ScrollBarThickness=2; s.ScrollBarImageColor3=T.BORDER
        s.CanvasSize=UDim2.new(0,0,0,0); s.AutomaticCanvasSize=Enum.AutomaticSize.Y
        s.Parent=frame
        local ll=Instance.new("UIListLayout"); ll.FillDirection=Enum.FillDirection.Vertical
        ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,5); ll.Parent=s
        local p=Instance.new("UIPadding")
        p.PaddingLeft=UDim.new(0,4); p.PaddingRight=UDim.new(0,4)
        p.PaddingTop=UDim.new(0,5); p.PaddingBottom=UDim.new(0,5); p.Parent=s
        return s
    end

    self._frame=frame; self._cols={makeCol(0,4),makeCol(0.5,1)}; self._colIdx=0; self._sections={}
    return self
end

function Tab:createsection(title)
    local col=self._cols[(self._colIdx%2)+1]; self._colIdx=self._colIdx+1
    local sec=Section.new(col,title); table.insert(self._sections,sec)
    return sec
end

-- ═══════════════════════════════════════════════════════════════════════════
--  WINDOW
-- ═══════════════════════════════════════════════════════════════════════════
local Window = {}
Window.__index = Window

function Window.new(title, defaultKey)
    local self=setmetatable({},Window)

    local sg=Instance.new("ScreenGui")
    sg.Name="DigzUI"; sg.ResetOnSpawn=false
    sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder=999
    sg.IgnoreGuiInset=true   -- prevents UI being pushed down by topbar on mobile
    sg.Parent=playerGui

    -- responsive size: smaller on mobile touch screens
    local WIN_W_ACT = IS_MOBILE and 420 or WIN_W
    local WIN_H_ACT = IS_MOBILE and 340 or WIN_H

    local win=Instance.new("Frame")
    win.Name="Window"
    win.Size=UDim2.new(0,WIN_W_ACT,0,WIN_H_ACT)
    win.Position=UDim2.new(0.5,-WIN_W_ACT/2,0.5,-WIN_H_ACT/2)
    win.BackgroundColor3=T.BG; win.BorderSizePixel=0; win.ClipsDescendants=false
    win.Parent=sg; rnd(win,6); brd(win,T.BORDER,1)

    -- ── Title bar ─────────────────────────────────────────────────────────
    local titleBar=Instance.new("Frame")
    titleBar.Size=UDim2.new(1,0,0,HEADER_H)
    titleBar.BackgroundColor3=T.TAB_BG; titleBar.BorderSizePixel=0; titleBar.Parent=win

    -- left accent stripe
    local accent=Instance.new("Frame")
    accent.Size=UDim2.new(0,3,0.55,0); accent.Position=UDim2.new(0,8,0.225,0)
    accent.BackgroundColor3=T.ACCENT; accent.BorderSizePixel=0; accent.Parent=titleBar; rnd(accent,2)

    -- title text
    local titleLbl=lbl(titleBar,title,12,T.TEXT,FONT_SEMI)
    titleLbl.Size=UDim2.new(1,-140,1,0); titleLbl.Position=UDim2.new(0,18,0,0)

    -- ── Key badge (click to rebind) ───────────────────────────────────────
    -- stored on self._keyHolder so setkey() can update it from outside
    self._keyHolder = {key = defaultKey or Enum.KeyCode.RightShift}
    local listeningForKey = false

    local keyBadge = Instance.new("TextButton")
    keyBadge.Size=UDim2.new(0,70,0,20); keyBadge.Position=UDim2.new(1,-98,0.5,-10)
    keyBadge.BackgroundColor3=T.KEY_BG; keyBadge.BorderSizePixel=0
    keyBadge.Text=tostring(self._keyHolder.key):gsub("Enum.KeyCode.","")
    keyBadge.TextColor3=T.ACCENT; keyBadge.Font=FONT; keyBadge.TextSize=11
    keyBadge.Parent=titleBar; rnd(keyBadge,4); brd(keyBadge,T.ACCENT,1)
    self._keyBadge = keyBadge  -- stored so setkey can update the label too

    -- tooltip
    local keyTip=lbl(titleBar,"toggle key",10,T.TEXT_DIM,FONT,Enum.TextXAlignment.Center)
    keyTip.Size=UDim2.new(0,70,0,12); keyTip.Position=UDim2.new(1,-98,1,2)
    keyTip.BackgroundTransparency=1

    -- close button
    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,20,0,20); closeBtn.Position=UDim2.new(1,-26,0.5,-10)
    closeBtn.BackgroundColor3=T.RED; closeBtn.BorderSizePixel=0
    closeBtn.Text="✕"; closeBtn.TextColor3=Color3.new(1,1,1)
    closeBtn.Font=FONT_BOLD; closeBtn.TextSize=11; closeBtn.Parent=titleBar; rnd(closeBtn,10)
    closeBtn.MouseEnter:Connect(function() tw(closeBtn,{BackgroundColor3=Color3.fromRGB(255,90,90)},0.08) end)
    closeBtn.MouseLeave:Connect(function() tw(closeBtn,{BackgroundColor3=T.RED},0.08) end)

    -- ── Tab bar ───────────────────────────────────────────────────────────
    local tabBar=Instance.new("Frame")
    tabBar.Size=UDim2.new(1,0,0,TABBAR_H); tabBar.Position=UDim2.new(0,0,0,HEADER_H)
    tabBar.BackgroundColor3=T.SURFACE; tabBar.BorderSizePixel=0; tabBar.Parent=win
    local tl=Instance.new("UIListLayout"); tl.FillDirection=Enum.FillDirection.Horizontal
    tl.SortOrder=Enum.SortOrder.LayoutOrder; tl.Padding=UDim.new(0,1); tl.Parent=tabBar
    local tp=Instance.new("UIPadding"); tp.PaddingLeft=UDim.new(0,4); tp.Parent=tabBar

    -- separator
    local sep=Instance.new("Frame")
    sep.Size=UDim2.new(1,0,0,SEP_H); sep.Position=UDim2.new(0,0,0,HEADER_H+TABBAR_H)
    sep.BackgroundColor3=T.BORDER; sep.BorderSizePixel=0; sep.Parent=win

    -- ── Content area ──────────────────────────────────────────────────────
    local CONTENT_TOP = HEADER_H+TABBAR_H+SEP_H
    local content=Instance.new("Frame")
    content.Size=UDim2.new(1,0,1,-CONTENT_TOP)
    content.Position=UDim2.new(0,0,0,CONTENT_TOP)
    content.BackgroundTransparency=1; content.Parent=win
    -- NOTE: no ClipsDescendants on content so dropdowns can overflow

    -- ── Mobile ☰ button ───────────────────────────────────────────────────
    local mobileBtn
    if IS_MOBILE then
        mobileBtn=Instance.new("TextButton")
        mobileBtn.Size=UDim2.new(0,46,0,46); mobileBtn.Position=UDim2.new(1,-56,1,-56)
        mobileBtn.BackgroundColor3=T.ACCENT; mobileBtn.BorderSizePixel=0
        mobileBtn.Text="☰"; mobileBtn.TextColor3=Color3.new(1,1,1)
        mobileBtn.Font=FONT_BOLD; mobileBtn.TextSize=22; mobileBtn.ZIndex=100
        mobileBtn.Parent=sg; rnd(mobileBtn,23); brd(mobileBtn,T.ACCENT_DIM,2)
    end

    makeDraggable(titleBar, win)

    -- ── Open / Close ──────────────────────────────────────────────────────
    self._win=win; self._tabBar=tabBar; self._content=content
    self._tabs={}; self._visible=true
    self._winSize=UDim2.new(0,WIN_W_ACT,0,WIN_H_ACT)

    -- guard: ignore any close calls for the first 0.5s after creation
    local spawnTime = tick()
    local SPAWN_GUARD = 0.5

    local function closeWindow()
        if not self._visible then return end
        if (tick() - spawnTime) < SPAWN_GUARD then return end
        self._visible=false
        win.ClipsDescendants=true
        tw(win,{Size=UDim2.new(0,WIN_W_ACT,0,0)},0.18)
        task.delay(0.2,function() win.Visible=false; win.Size=self._winSize end)
        if mobileBtn then tw(mobileBtn,{BackgroundColor3=T.ACCENT_DIM},0.1) end
    end

    local function openWindow()
        if self._visible then return end
        self._visible=true
        win.Size=UDim2.new(0,WIN_W_ACT,0,0); win.Visible=true
        win.ClipsDescendants=true
        tw(win,{Size=self._winSize},0.18)
        task.delay(0.2,function() win.ClipsDescendants=false end)
        if mobileBtn then tw(mobileBtn,{BackgroundColor3=T.ACCENT},0.1) end
    end

    -- close button: MouseButton1Click only (TouchTap can misfire on spawn)
    closeBtn.MouseButton1Click:Connect(closeWindow)
    closeBtn.TouchTap:Connect(function()
        if (tick() - spawnTime) < SPAWN_GUARD then return end
        closeWindow()
    end)

    if mobileBtn then onClick(mobileBtn,function() if self._visible then closeWindow() else openWindow() end end) end

    -- Key badge click → listen for next keypress to rebind
    onClick(keyBadge, function()
        if listeningForKey then return end
        listeningForKey = true
        keyBadge.Text = "..."; keyBadge.TextColor3 = T.RED
    end)

    -- Single InputBegan: handles rebind OR toggle — no duplicate listeners
    UIS.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.UserInputType == Enum.UserInputType.Keyboard then
            if listeningForKey then
                -- rebind: update keyHolder AND badge label
                listeningForKey = false
                self._keyHolder.key = i.KeyCode
                keyBadge.Text = tostring(i.KeyCode):gsub("Enum.KeyCode.","")
                keyBadge.TextColor3 = T.ACCENT
            elseif i.KeyCode == self._keyHolder.key then
                if (tick() - spawnTime) < SPAWN_GUARD then return end
                if self._visible then closeWindow() else openWindow() end
            end
        end
    end)

    self._closeWindow=closeWindow
    self._openWindow=openWindow

    -- ensure visible and full size on spawn
    win.Visible = true
    win.Size = self._winSize
    win.ClipsDescendants = false
    self._visible = true

    return self
end

function Window:open()  self._openWindow()  end
function Window:close() self._closeWindow() end

-- setkey: update the toggle key from code — also updates the badge in the title bar
function Window:setkey(newKey)
    self._keyHolder.key = newKey
    self._keyBadge.Text = tostring(newKey):gsub("Enum.KeyCode.","")
    self._keyBadge.TextColor3 = T.ACCENT
end

function Window:createtab(name)
    local idx=#self._tabs+1
    local tab=Tab.new(self._content)

    local btn=Instance.new("TextButton")
    btn.Size=UDim2.new(0,85,1,0); btn.BackgroundColor3=T.SURFACE; btn.BorderSizePixel=0
    btn.Text=name; btn.TextColor3=T.TAB_INACTIVE; btn.Font=FONT; btn.TextSize=12
    btn.LayoutOrder=idx; btn.Parent=self._tabBar

    local ind=Instance.new("Frame")
    ind.Size=UDim2.new(0.6,0,0,2); ind.Position=UDim2.new(0.2,0,1,-2)
    ind.BackgroundColor3=T.ACCENT; ind.BorderSizePixel=0; ind.Visible=false; ind.Parent=btn; rnd(ind,1)

    onClick(btn,function() self:_switch(idx) end)
    self._tabs[idx]={tab=tab,btn=btn,ind=ind}
    if idx==1 then self:_switch(1) end
    return tab
end

function Window:_switch(idx)
    for i,d in ipairs(self._tabs) do
        local a=(i==idx); d.tab._frame.Visible=a; d.ind.Visible=a
        tw(d.btn,{TextColor3=a and T.TAB_ACTIVE or T.TAB_INACTIVE, BackgroundColor3=a and T.SURFACE2 or T.SURFACE},0.1)
    end
end

